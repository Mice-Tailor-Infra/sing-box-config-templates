{
  "log": {
    "disabled": false,
    "level": "fatal",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "zashboard",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip",
      "external_ui_download_detour": "🔰 节点选择",
      "secret": "${CLASH_API_SECRET}",
      "default_mode": "rule"
    },
    "cache_file": {
      "enabled": true,
      "store_rdrc": true,
      "store_fakeip": false
    }
  },
  "dns": {
    "servers": [
      {
        "type": "local",
        "tag": "local"
      },
      {
        "tag": "google",
        "type": "https",
        "server": "8.8.4.4",
        "domain_resolver": "China",
        "detour": "🔰 节点选择",
        "strategy": "ipv4_only"
      },
      {
        "tag": "China",
        "type": "https",
        "server": "223.5.5.5",
        "domain_resolver": "local",
        "strategy": "ipv4_only"
      },
      {
        "tag": "fcm_hosts",
        "type": "hosts",
        "path": "/data/adb/fcm-hosts/hosts"
      },
      "{{DNS_SERVERS}}"
    ],
    "rules": [
      "{{DNS_RULES_TOP}}",
      // 1. 广告拦截
      {
        "rule_set": ["geosite-category-ads-all"],
        "action": "reject"
      },
      // 2. Clash Direct 模式
      {
        "clash_mode": "Direct",
        "server": "China"
      },
      // 3. FCM 专项: 强制从本地 hosts 文件解析
      {
        "rule_set": "geosite-googlefcm",
        "server": "fcm_hosts",
        "disable_cache": true
      },
      // 4. Clash Global 模式
      {
        "clash_mode": "Global",
        "query_type": ["A"],
        "server": "google",
        "strategy": "ipv4_only"
      },
      // 5. Steam CN 域名 → China (Real-IP，确保 IPCountry: CN)
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain": [
              "cm.steampowered.com",
              "steamserver.net",
              "steamcontent.com",
              "steamstatic.com"
            ]
          },
          { "rule_set": "geosite-steam@cn" }
        ],
        "server": "China"
      },
      // 6. CN 域名 (单层) → China
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain": [
              "beautifulcarrot.com",
              "0xc.xyz",
              "0xc.cn",
              "ash.do",
              "ash6.com",
              "dl.google.com"
            ],
            "domain_suffix": [
              "youtune.tech"
            ]
          },
          {
            "rule_set": [
              "geosite-cn",
              "geosite-microsoft@cn",
              "geosite-google@cn",
              "geosite-googlefcm"
            ]
          }
        ],
        "server": "China"
      },
      "{{DNS_RULES_MID}}",
      // 7. Google Play 区域修复域名 → google (走代理 DNS)
      {
        "domain": [
          "services.googleapis.cn",
          "googleapis.cn",
          "xn--ngstr-lra8j.com",
          "xn--ngstr-cn-8za9o.com"
        ],
        "server": "google"
      },
      // 8. 外国域名 → google
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "google",
        "strategy": "ipv4_only"
      },
      "{{DNS_RULES_BOTTOM}}"
    ],
    "final": "google",
    "strategy": "ipv4_only",
    "independent_cache": true,
    "reverse_mapping": true
  },
  "inbounds": [
    "{{INBOUNDS_TOP}}",
    {
      "type": "tun",
      "tag": "tun-in",
      "stack": "mixed",
      "address": ["172.19.0.1/30"],
      "auto_route": true,
      "auto_redirect": true,
      "strict_route": true,
      "mtu": 9000,
      "route_exclude_address": [
        "192.168.43.0/24",
        "192.168.49.0/24",
        "172.20.10.0/24"
      ],
      "route_exclude_address_set": ["geoip-cn"],
      "exclude_package": [
        // --- 1. 局域网协作与投屏 ---
        "org.kde.kdeconnect_tp",
        "com.oplus.cast",
        "com.oplus.ocar",
        "com.heytap.opluscarlink",
        "com.microsoft.appmanager",
        "com.heytap.accessory",

        // --- 2. 核心通信 (电话/短信/基带) ---
        "com.android.phone",
        "com.android.stk",
        "com.android.server.telecom",
        "com.android.incallui",
        "com.android.mms",
        "com.android.cellbroadcastreceiver",
        "com.android.cellbroadcastservice",
        "com.qualcomm.qti.telephonyservice",
        "com.qualcomm.qti.cne",
        "com.qualcomm.qti.iwlan",
        "org.codeaurora.ims",
        "com.google.android.ims",
        "vendor.qti.imsdatachannel",
        "com.qualcomm.qti.imscmservice",

        // --- 3. 网络底层与热点 ---
        "com.android.networkstack.tethering",
        "com.android.captiveportallogin",
        "com.google.android.captiveportallogin",

        // --- 4. 硬件驱动与安全层 ---
        "com.android.nfc",
        "com.android.bluetooth",
        "com.fido.asm",
        "com.fido.uafclient",
        "com.fido.fido2client",
        "com.oplus.securitykeyboard",
        "com.surcumference.fingerprintpay",

        // --- 5. 系统组件 (OTA 等) ---
        "com.oplus.ota",
        "com.oplus.romupdate",
        "com.oplus.sau",
        "com.oplus.sauhelper",
        "com.coloros.translate",

        // --- 6. 用户自定义白名单 ---
        "com.alibaba.android.rimet",
        "com.tencent.mm",
        "com.unionpay",
        "com.icbc",
        "com.MobileTicket",
        "com.taobao.idlefish",
        "com.bilibili.app.in",
        "tv.danmaku.bili",
        "com.larus.nova",
        "com.tencent.mobileqq",
        "com.deepseek.chat",
        "com.ss.android.ugc.aweme"
      ]
    },
    {
      "type": "mixed",
      "listen": "0.0.0.0",
      "listen_port": 7890,
      "users": [
        {
          "username": "${MIXED_PROXY_USERNAME}",
          "password": "${MIXED_PROXY_PASSWORD}"
        }
      ]
    },
    {
      "type": "mixed",
      "listen": "127.0.0.1",
      "listen_port": 7891
    },
    {
      "type": "direct",
      "tag": "dns-in",
      "network": "udp",
      "listen": "127.0.0.1",
      "listen_port": 6053
    },
    "{{INBOUNDS_BOTTOM}}"
  ],
  "providers": [
    {
      "tag": "${PROVIDER_NAME_1}",
      "type": "remote",
      "url": "${SUB_URL_1}",
      "path": "./provider_1_cache.yaml",
      "update_interval": "12h",
      "user_agent": "clash.meta",
      "download_detour": "🇨🇳 国内直连",
      "health_check": {
        "enabled": false
      }
    },
    {
      "tag": "${PROVIDER_NAME_2}",
      "type": "remote",
      "url": "${SUB_URL_2}",
      "path": "./provider_2_cache.yaml",
      "update_interval": "12h",
      "user_agent": "clash.meta",
      "download_detour": "🇨🇳 国内直连",
      "health_check": {
        "enabled": false
      }
    },
    {
      "tag": "${PROVIDER_NAME_3}",
      "type": "remote",
      "url": "${SUB_URL_3}",
      "path": "./provider_3_cache.yaml",
      "update_interval": "12h",
      "user_agent": "clash.meta",
      "download_detour": "🇨🇳 国内直连",
      "health_check": {
        "enabled": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "🔰 节点选择",
      "type": "selector",
      "outbounds": [
        "⚡ 联通移动优选",
        "⚡ 电信优选",
        "🇯🇵 大阪软银",
        "📦 大流量",
        "🌀 手动选择1",
        "🌀 手动选择2",
        "🌀 手动选择3",
        "📲 电报消息",
        "🇨🇳 国内直连"
      ],
      "default": "⚡ 联通移动优选"
    },
    {
      "tag": "⚡ 联通移动优选",
      "type": "urltest",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "include": "(?i)s[12]\\b",
      "url": "http://connectivitycheck.gstatic.com/generate_204",
      "tolerance": 50,
      "interval": "3m",
      "idle_timeout": "30m",
      "interrupt_exist_connections": false
    },
    {
      "tag": "⚡ 电信优选",
      "type": "urltest",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "include": "(?i)s[35]\\b",
      "url": "http://connectivitycheck.gstatic.com/generate_204",
      "tolerance": 50,
      "interval": "3m",
      "idle_timeout": "30m",
      "interrupt_exist_connections": false
    },
    {
      "tag": "🇯🇵 大阪软银",
      "type": "urltest",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "include": "(?i)s4\\b",
      "url": "http://connectivitycheck.gstatic.com/generate_204",
      "tolerance": 50,
      "interval": "3m",
      "idle_timeout": "30m",
      "interrupt_exist_connections": false
    },
    {
      "tag": "📦 大流量",
      "type": "selector",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "include": "(?i)s801\\b"
    },
    {
      "tag": "🌀 手动选择1",
      "type": "selector",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "use_all_providers": true
    },
    {
      "tag": "🌀 手动选择2",
      "type": "selector",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "use_all_providers": true
    },
    {
      "tag": "🌀 手动选择3",
      "type": "selector",
      "providers": [
        "${PROVIDER_NAME_1}",
        "${PROVIDER_NAME_2}",
        "${PROVIDER_NAME_3}"
      ],
      "use_all_providers": true
    },
    {
      "tag": "📲 电报消息",
      "type": "selector",
      "outbounds": [
        "⚡ 联通移动优选",
        "⚡ 电信优选",
        "🇯🇵 大阪软银",
        "📦 大流量",
        "🌀 手动选择1",
        "🌀 手动选择2",
        "🌀 手动选择3",
        "🇨🇳 国内直连"
      ],
      "default": "⚡ 联通移动优选"
    },
    {
      "tag": "🔞 18comic",
      "type": "selector",
      "outbounds": [
        "🔰 节点选择",
        "⚡ 联通移动优选",
        "⚡ 电信优选",
        "🇯🇵 大阪软银",
        "📦 大流量",
        "🌀 手动选择1",
        "🌀 手动选择2",
        "🌀 手动选择3",
        "🇨🇳 国内直连"
      ],
      "default": "🔰 节点选择"
    },
    {
      "tag": "🎮 dlsite",
      "type": "selector",
      "outbounds": [
        "🔰 节点选择",
        "⚡ 联通移动优选",
        "⚡ 电信优选",
        "🇯🇵 大阪软银",
        "📦 大流量",
        "🌀 手动选择1",
        "🌀 手动选择2",
        "🌀 手动选择3",
        "🇨🇳 国内直连"
      ],
      "default": "🇯🇵 大阪软银"
    },
    {
      "tag": "🎮 Steam商店",
      "type": "selector",
      "outbounds": [
        "🔰 节点选择",
        "⚡ 联通移动优选",
        "⚡ 电信优选",
        "🇯🇵 大阪软银",
        "🌀 手动选择1",
        "🌀 手动选择2",
        "🌀 手动选择3",
        "🇨🇳 国内直连"
      ]
    },
    {
      "tag": "🇨🇳 国内直连",
      "type": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "China",
    "final": "🔰 节点选择",
    "rules": [
      "{{ROUTE_RULES_TOP}}",
      // 1. 协议嗅探
      { "action": "sniff" },
      // 2. DNS 劫持
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "protocol": "dns" },
          { "port": 53 },
          { "inbound": ["dns-in"] }
        ],
        "action": "hijack-dns"
      },
      // 3. 私有地址/LAN/NTP/BitTorrent 直连
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "ip_is_private": true },
          { "protocol": ["ntp", "bittorrent"] },
          { "port": 123 },
          { "domain_suffix": [".lan"] }
        ],
        "outbound": "🇨🇳 国内直连"
      },
      // 4. Clash 模式覆盖
      {
        "clash_mode": "Direct",
        "outbound": "🇨🇳 国内直连"
      },
      {
        "clash_mode": "Global",
        "outbound": "🔰 节点选择"
      },
      // 5. 广告拦截
      {
        "rule_set": ["geosite-category-ads-all"],
        "action": "reject"
      },
      // 6. 协议封锁 (DoT/QUIC/STUN)
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "port": 853 },
          { "network": "udp", "port": 443 },
          { "protocol": ["stun", "quic"] }
        ],
        "action": "reject"
      },
      // 7. Steam CDN/下载 → 直连 (Dogfight360 方案)
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain_suffix": [
              "cm.steampowered.com",
              "steamserver.net",
              "steamcontent.com"
            ]
          },
          { "rule_set": "geosite-steam@cn" },
          {
            "ip_cidr": [
              "45.121.184.0/24",
              "103.10.124.0/23",
              "103.28.54.0/24",
              "146.66.152.0/24",
              "146.66.155.0/24",
              "153.254.86.0/24",
              "155.133.224.0/22",
              "155.133.230.0/24",
              "155.133.232.0/23",
              "155.133.234.0/24",
              "155.133.236.0/22",
              "155.133.240.0/23",
              "155.133.244.0/23",
              "155.133.246.0/24",
              "155.133.248.0/21",
              "162.254.192.0/21",
              "185.25.182.0/23",
              "190.217.32.0/22",
              "192.69.96.0/22",
              "205.196.6.0/24",
              "208.64.200.0/22",
              "208.78.164.0/22",
              "205.185.194.0/24"
            ]
          }
        ],
        "outbound": "🇨🇳 国内直连"
      },
      // 8. Steam 商店/社区 → 代理
      { "rule_set": "geosite-steam", "outbound": "🎮 Steam商店" },
      // 9. Telegram 电报 → 代理
      { "rule_set": ["geoip-telegram", "geosite-telegram"], "outbound": "📲 电报消息" },
      // 10. 18comic 成人漫画 → 代理
      {
        "domain_suffix": [
          "18comic.com",
          "18comic.vip",
          "18comic2.com",
          "buka18.com"
        ],
        "outbound": "🔞 18comic"
      },
      // 11. dlsite 日本同人 → 代理
      {
        "domain_suffix": [
          "dlsite.com",
          "dlsite.jp"
        ],
        "outbound": "🎮 dlsite"
      },
      // 11. Google Play 区域修复 → 代理
      {
        "domain": [
          "googleapis.cn",
          "services.googleapis.cn",
          "xn--ngstr-lra8j.com",
          "xn--ngstr-cn-8za9o.com"
        ],
        "rule_set": ["geosite-google-play@cn"],
        "outbound": "🔰 节点选择"
      },
      // 10. CN 域名直连 (单层)
      {
        "rule_set": [
          "geosite-cn",
          "geosite-category-games@cn",
          "geosite-microsoft@cn",
          "geosite-google@cn",
          "geosite-googlefcm"
        ],
        "domain": [
          "beautifulcarrot.com",
          "0xc.xyz",
          "0xc.cn",
          "ash.do",
          "ash6.com",
          "dl.google.com"
        ],
        "domain_suffix": ["youtune.tech"],
        "outbound": "🇨🇳 国内直连"
      },
      // 11. 外国域名 → 代理 (Android 无进程白名单，用 exclude_package 替代)
      { "rule_set": "geosite-geolocation-!cn", "outbound": "🔰 节点选择" },
      "{{ROUTE_RULES_MID}}",
      // 12. GeoIP CN 兜底 → 直连
      { "rule_set": "geoip-cn", "outbound": "🇨🇳 国内直连" },
      "{{ROUTE_RULES_BOTTOM}}"
      // final → 🔰 节点选择 (在 route.final 中定义)
    ],
    "rule_set": [
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/cn.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/cn.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geosite-geolocation-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/geolocation-!cn.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geosite-steam@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/steam@cn.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geosite-steam",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/steam.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geosite-google@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/google@cn.srs",
        "download_detour": "🔰 节点选择"
      },
      {
        "tag": "geosite-google-play@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/google-play@cn.srs",
        "download_detour": "🔰 节点选择"
      },
      {
        "tag": "geosite-googlefcm",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/googlefcm.srs",
        "download_detour": "🔰 节点选择"
      },
      {
        "tag": "geosite-category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/category-ads-all.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geosite-category-games@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/category-games@cn.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geosite-microsoft@cn",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/microsoft@cn.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
      {
        "tag": "geoip-telegram",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/telegram.srs",
        "download_detour": "🔰 节点选择",
        "update_interval": "3d"
      },
