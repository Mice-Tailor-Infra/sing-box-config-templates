CLASH_API_SECRET=replace_me
MIXED_PROXY_USERNAME=admin
MIXED_PROXY_PASSWORD=replace_me

# 单一上游提供商，仅保留一条订阅入口。
PROVIDER_NAME_1=🛫 JustMySocks

# 关键要求:
# 1. 这里应当是“纯节点列表”订阅，而不是带 proxy-groups/rules 的整份 Clash 配置。
# 2. 如果你继续使用 api.wcc.best 这类订阅转换器，请把 list=false 改成 list=true。
# 3. sing-box 使用 meta-rules-dat 的 sing 分支；mihomo 使用同仓库的 meta 分支。
SUB_URL_1=https://api.example.invalid/sub?target=clash&list=true
