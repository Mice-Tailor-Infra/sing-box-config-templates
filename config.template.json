  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "China",
    "final": "🔰 节点选择",
    "rules": [
      // 1. 协议嗅探
      { "action": "sniff" },
      // 2. DNS 劫持
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "protocol": "dns" },
          { "port": 53 },
          { "inbound": ["dns-in"] }
        ],
        "action": "hijack-dns"
      },
      // 3. 私有地址/LAN/NTP/BitTorrent 直连
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "ip_is_private": true },
          { "protocol": ["ntp", "bittorrent"] },
          { "port": 123 },
          { "domain_suffix": [".lan"] }
        ],
        "outbound": "🇨🇳 国内直连"
      },
      // 4. Clash 模式覆盖
      {
        "clash_mode": "Direct",
        "outbound": "🇨🇳 国内直连"
      },
      {
        "clash_mode": "Global",
        "outbound": "🔰 节点选择"
      },
      // 5. 广告拦截
      {
        "rule_set": ["geosite-category-ads-all"],
        "action": "reject"
      },
      // 6. 协议封锁 (DoT/QUIC/STUN)
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "port": 853 },
          { "network": "udp", "port": 443 },
          { "protocol": ["stun", "quic"] }
        ],
        "action": "reject"
      },
      // 7. Steam CDN/下载 → 直连 (Dogfight360 方案)
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain_suffix": [
              "cm.steampowered.com",
              "steamserver.net",
              "steamcontent.com"
            ]
          },
          { "rule_set": "geosite-steam@cn" },
          {
            "ip_cidr": [
              "45.121.184.0/24",
              "103.10.124.0/23",
              "103.28.54.0/24",
              "146.66.152.0/24",
              "146.66.155.0/24",
              "153.254.86.0/24",
              "155.133.224.0/22",
              "155.133.230.0/24",
              "155.133.232.0/23",
              "155.133.234.0/24",
              "155.133.236.0/22",
              "155.133.240.0/23",
              "155.133.244.0/23",
              "155.133.246.0/24",
              "155.133.248.0/21",
              "162.254.192.0/21",
              "185.25.182.0/23",
              "190.217.32.0/22",
              "192.69.96.0/22",
              "205.196.6.0/24",
              "208.64.200.0/22",
              "208.78.164.0/22",
              "205.185.194.0/24"
            ]
          }
        ],
        "outbound": "🇨🇳 国内直连"
      },
      // 8. Steam 商店/社区 → 服务组
      { "rule_set": "geosite-steam", "outbound": "🎮 Steam" },
      // 9. Telegram 电报 → 服务组
      {
        "rule_set": ["geoip-telegram", "geosite-telegram"],
        "outbound": "📲 Telegram"
      },
      // 10. 18comic 成人漫画 → 服务组
      {
        "domain_suffix": [
          "18comic.com",
          "18comic.vip",
          "18comic2.com",
          "buka18.com"
        ],
        "outbound": "🔞 18comic"
      },
      // 11. dlsite 日本同人 → 服务组
      {
        "domain_suffix": ["dlsite.com", "dlsite.jp"],
        "outbound": "🎮 dlsite"
      },
      // 12. AI 中转站直连例外
      {
        "domain": ["api-s.zwenooo.link", "ai.yescode.cloud"],
        "domain_suffix": ["ikuncode.cc"],
        "outbound": "🇨🇳 国内直连"
      },
      // 13. AI 服务 → 服务组
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain": ["api.zwenooo.link", "codez.zwenooo.link"]
          },
          {
            "domain": [
              "alkalicore-pa.clients6.google.com",
              "alkalimakersuite-pa.clients6.google.com",
              "webchannel-alkalimakersuite-pa.clients6.google.com",
