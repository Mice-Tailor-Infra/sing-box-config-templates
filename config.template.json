          }
        ],
        "outbound": "🤖 AI"
      },
      // 14. Google FCM → 直连
      {
        "rule_set": ["geosite-googlefcm"],
        "outbound": "🇨🇳 国内直连"
      },
      // 15. Google 服务 → 服务组
