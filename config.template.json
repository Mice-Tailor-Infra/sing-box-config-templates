{
  "log": {
    "disabled": false,
    "level": "fatal",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "zashboard",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip",
      "external_ui_download_detour": "🔰 节点选择",
      "secret": "${CLASH_API_SECRET}",
      "default_mode": "rule"
    },
    "cache_file": {
      "enabled": true,
      "store_rdrc": true,
      "store_fakeip": false
    }
  },
  "dns": {
    "servers": [
      {
        "type": "local",
        "tag": "local"
      },
      {
        "tag": "google",
        "type": "https",
        "server": "8.8.4.4",
        "domain_resolver": "China",
        "detour": "🔰 节点选择",
        "strategy": "ipv4_only"
      },
      {
        "tag": "China",
        "type": "https",
        "server": "223.5.5.5",
        "domain_resolver": "local",
        "strategy": "ipv4_only"
      }
    ],
    "rules": [
      // 1. 广告拦截
      {
        "rule_set": ["geosite-category-ads-all"],
        "action": "reject"
      },
      // 2. Clash Direct 模式
      {
        "clash_mode": "Direct",
        "server": "China"
      },
      // 3. Clash Global 模式
      {
        "clash_mode": "Global",
        "query_type": ["A"],
        "server": "google",
        "strategy": "ipv4_only"
      },
      // 4. Steam CN 域名 → China (Real-IP，确保 IPCountry: CN)
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain": [
              "cm.steampowered.com",
              "steamserver.net",
              "steamcontent.com",
              "steamstatic.com"
            ]
          },
          { "rule_set": "geosite-steam@cn" }
        ],
        "server": "China"
      },
      // 5. CN 域名与 FCM → China
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "domain": [
              "beautifulcarrot.com",
              "0xc.xyz",
              "0xc.cn",
              "ash.do",
              "ash6.com",
              "dl.google.com"
            ],
            "domain_suffix": ["youtune.tech", "yescode.cloud", "ikuncode.cc"],
            "domain": ["api-s.zwenooo.link"]
          },
          {
            "rule_set": [
              "geosite-cn",
              "geosite-microsoft@cn",
              "geosite-google@cn",
              "geosite-googlefcm"
            ]
          }
        ],
        "server": "China"
      },
      // 6. Google Play 区域修复域名 → google (走代理 DNS)
      {
        "domain": [
          "services.googleapis.cn",
          "googleapis.cn",
          "xn--ngstr-lra8j.com",
          "xn--ngstr-cn-8za9o.com"
        ],
        "server": "google"
      },
      // 7. 外国域名 → google
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "google",
        "strategy": "ipv4_only"
      }
    ],
    "final": "google",
    "strategy": "ipv4_only",
    "independent_cache": true,
    "reverse_mapping": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "stack": "mixed",
      "address": ["172.19.0.1/30"],
      "auto_route": true,
      "strict_route": false,
      "mtu": 9000,
      "route_exclude_address": [
        "173.73.48.0/24",
        "10.42.0.0/24",
        "150.50.11.22/32",
        "150.50.13.11/32",
        "150.50.13.13/32",
        "175.11.5.2/32",
        "175.13.1.2/32",
        "175.13.1.3/32"
      ],
      "route_exclude_address_set": ["geoip-cn"]
    },
    {
      "type": "mixed",
      "listen": "0.0.0.0",
      "listen_port": 7890,
      "users": [
        {
          "username": "${MIXED_PROXY_USERNAME}",
          "password": "${MIXED_PROXY_PASSWORD}"
        }
      ]
    },
    {
      "type": "mixed",
      "listen": "0.0.0.0",
      "listen_port": 7891
    },
    {
      "type": "direct",
      "tag": "dns-in",
      "network": "udp",
      "listen": "127.0.0.1",
      "listen_port": 6053
    }
  ],
  "providers": [
    {
      "tag": "${PROVIDER_NAME_1}",
      "type": "remote",
      "url": "${SUB_URL_1}",
      "path": "./provider_cache.yaml",
      "update_interval": "3h",
      "user_agent": "clash.meta",
      "download_detour": "🇨🇳 国内直连",
      "health_check": {
        "enabled": false
      }
    }
  ],
